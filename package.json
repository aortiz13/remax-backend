{
    "name": "remax-backend",
    "version": "1.0.0",
    "type": "module",
    "description": "RE/MAX Exclusive CRM - API Server & Background Worker",
    "scripts": {
        "dev:api": "node --watch --env-file=.env src/server.js",
        "dev:worker": "node --watch --env-file=.env src/worker.js",
        "start:api": "node src/server.js",
        "start:worker": "node src/worker.js"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.700.0",
        "@aws-sdk/s3-request-presigner": "^3.1008.0",
        "@supabase/supabase-js": "^2.45.1",
        "bullmq": "^5.30.0",
        "busboy": "^1.6.0",
        "cors": "^2.8.5",
        "express": "^4.21.0",
        "googleapis": "^144.0.0",
        "helmet": "^8.0.0",
        "http-proxy-middleware": "^3.0.5",
        "ioredis": "^5.4.1",
        "jsonwebtoken": "^9.0.2",
        "node-cron": "^3.0.3",
        "pg": "^8.13.0"
    }
}
