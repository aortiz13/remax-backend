# ─── Chatwoot (WhatsApp via self-hosted Chatwoot) ────────────────
# Used by the recruitment automation rules (action_type = 'send_whatsapp')
# and by the manual /api/recruitment/candidates/:id/send-whatsapp endpoint.
# The api_access_token must belong to an Agent / Agent-Bot that has access
# to the WhatsApp inbox.
CHATWOOT_API_URL=https://wssp.remax-exclusive.cl
CHATWOOT_API_TOKEN=your_chatwoot_agent_api_access_token
CHATWOOT_ACCOUNT_ID=2
CHATWOOT_INBOX_ID=your_whatsapp_inbox_id
# Label applied to the contact before sending (slug, lowercase).
CHATWOOT_LEAD_LABEL=postulante
# Conversation custom attribute key (NOT the display label — the slug
# from Settings → Custom Attributes) and the value used to turn the AI
# agent OFF. Booleans use 'true'/'false'; select attributes use the
# literal string value (e.g. 'off').
CHATWOOT_AI_AGENT_ATTRIBUTE_KEY=agente_ia
CHATWOOT_AI_AGENT_OFF_VALUE=false
